parameters:
    level: 5
    paths:
        - src
    # Most "if.alwaysTrue" reports at level 5 in our code come from
    # PHPDoc-derived types (FieldItemInterface, etc.) — we'd have to
    # tighten typehints on every iteration variable to fix them. Off
    # for now; if a real always-true if appears in our own logic the
    # baseline will surface it.
    treatPhpDocTypesAsCertain: false

includes:
    - phpstan-baseline.neon
